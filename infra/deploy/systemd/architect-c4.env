# Environment for architect-c4 systemd unit (V1 atom canon).
# Install: /etc/architect-c4/env  and EnvironmentFile= in the unit.

ARCHITECT_C4_DATA=/var/lib/architect-c4
ARCHITECT_C4_TRANSPORT=http
ARCHITECT_C4_HOST=127.0.0.1
ARCHITECT_C4_PORT=8766
ARCHITECT_C4_PATH=/mcp
ARCHITECT_C4_PUBLIC_BASE=https://c4.example.com
FASTMCP_SHOW_CLI_BANNER=false

# V1: only code/external/person/system as relationship endpoints.
# Set to 0 only while migrating legacy shell↔shell models.
ARCHITECT_C4_ATOM_EDGES=1
