# c4.example.com — Caddy TLS
# /mcp*           → vmcp gateway
# /, /adrs*, /flows*, /view* (legacy), /wasm* → architect-c4 HTTP viewer
c4.example.com {
	encode gzip

	handle /health {
		reverse_proxy 127.0.0.1:8765
	}

	handle /mcp* {
		reverse_proxy 127.0.0.1:8765 {
			flush_interval -1
		}
	}

	handle /mcp-proxy* {
		reverse_proxy 127.0.0.1:8765 {
			flush_interval -1
		}
	}

	handle /.well-known/* {
		reverse_proxy 127.0.0.1:8765
	}

	handle /adrs* {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}
	handle /flows* {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}
	# legacy aliases
	handle /view {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}
	handle /view/* {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}
	handle /wasm/* {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}

	# C4 viewer at site root
	handle / {
		reverse_proxy 127.0.0.1:8766 {
			flush_interval -1
		}
	}

	handle {
		respond "not found" 404
	}
}
