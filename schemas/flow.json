{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://c4.example.com/schemas/flow.json",
  "title": "architect-c4 Flow",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "kind"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "workspace_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "kind": {
      "type": "string",
      "enum": ["c4_dynamic", "sequence", "state"],
      "description": "v1 kinds. Agent default: c4_dynamic."
    },
    "usage_key": { "type": ["string", "null"], "maxLength": 120 },
    "scope_element_id": { "type": ["string", "null"] },
    "related_adrs": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string" }
    },
    "epoch": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "phase": { "type": ["string", "null"], "maxLength": 64 },
        "from": { "type": ["string", "null"] },
        "to": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"], "maxLength": 2000 }
      }
    },
    "steps": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["n", "from_id", "to_id"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "from_id": { "type": "string", "minLength": 1 },
          "to_id": { "type": "string", "minLength": 1 },
          "label": { "type": ["string", "null"], "maxLength": 200 }
        }
      }
    },
    "body": {
      "type": ["string", "null"],
      "maxLength": 50000,
      "description": "Mermaid body for sequence|state. Must start with sequenceDiagram or stateDiagram."
    },
    "anchors": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias"],
        "properties": {
          "alias": { "type": "string", "minLength": 1 },
          "element_id": { "type": ["string", "null"] },
          "adr_id": { "type": ["string", "null"] }
        }
      }
    },
    "refs": {
      "type": "array",
      "maxItems": 32,
      "description": "External documentation links (https only).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https://",
            "maxLength": 2000
          },
          "title": { "type": ["string", "null"], "maxLength": 200 }
        }
      }
    },
    "path": { "type": "string" },
    "git_commit_id": { "type": ["string", "null"] }
  }
}
