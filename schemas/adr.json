{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://c4.example.com/schemas/adr.json",
  "title": "architect-c4 ADR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "status",
    "decided_at",
    "context",
    "decision",
    "consequences"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$",
      "description": "Stable ADR id (also used as docs/adr/{id}.json basename)."
    },
    "workspace_id": {
      "type": "string",
      "description": "Filled by server; optional on upsert body."
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "status": {
      "type": "string",
      "description": "Agent may only write draft|proposed. Process sets accepted|rejected|deprecated|superseded.",
      "enum": [
        "draft",
        "proposed",
        "accepted",
        "rejected",
        "deprecated",
        "superseded"
      ]
    },
    "decided_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "scope_element_id": {
      "type": ["string", "null"],
      "description": "C4 element id or null for workspace-wide."
    },
    "context": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "decision": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "consequences": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "reason": {
      "type": ["string", "null"],
      "maxLength": 2000,
      "description": "Set only by set_adr_status when status=rejected."
    },
    "superseded_by_id": {
      "type": ["string", "null"],
      "description": "Required when status=superseded."
    },
    "related_flows": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string" },
      "description": "Flow ids (docs/flows/{id}.json) that illustrate this decision."
    },
    "refs": {
      "type": "array",
      "maxItems": 32,
      "description": "External documentation links (https only).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https://",
            "maxLength": 2000
          },
          "title": { "type": ["string", "null"], "maxLength": 200 }
        }
      }
    },
    "policy": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["enforce", "audit"], "default": "enforce" },
        "forbid": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from_kind", "to_kind", "code", "severity", "message"],
            "properties": {
              "from_kind": {
                "type": "string",
                "enum": [
                  "person",
                  "software_system",
                  "container",
                  "component",
                  "code",
                  "external"
                ]
              },
              "to_kind": {
                "type": "string",
                "enum": [
                  "person",
                  "software_system",
                  "container",
                  "component",
                  "code",
                  "external"
                ]
              },
              "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "severity": { "type": "string", "enum": ["error", "warning", "info"] },
              "message": { "type": "string", "minLength": 1, "maxLength": 2000 }
            }
          }
        }
      }
    },
    "path": { "type": "string" },
    "git_commit_id": { "type": ["string", "null"] }
  }
}
