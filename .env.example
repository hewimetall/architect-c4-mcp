# Sidecar: путь к docs/ продукта (истина на диске)
ARCHITECT_C4_DOCS=./docs
ARCHITECT_C4_WORKSPACE_ID=default

# Абсолютные ссылки viewer (только https://)
ARCHITECT_C4_PUBLIC_BASE=https://c4.example.com

# stdio | http
ARCHITECT_C4_TRANSPORT=stdio

# Локальный каталог sidecar (не кладите в git продукта; индексы в памяти)
# ARCHITECT_C4_DATA=./.data

# HTTP:
# ARCHITECT_C4_TRANSPORT=http
# ARCHITECT_C4_HOST=127.0.0.1
# ARCHITECT_C4_PORT=8766
# ARCHITECT_C4_PATH=/mcp

# Process gate для set_adr_status
# ARCHITECT_C4_PROCESS_TOKEN=
